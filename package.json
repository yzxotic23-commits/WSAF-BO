{
  "name": "whatsapp-auto-feeding",
  "version": "1.0.10",
  "description": "FeedFlow — WhatsApp Auto Feeding (AI pair conversations)",
  "main": "electron/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "node index.js",
    "desktop": "electron .",
    "codex-login": "npx @openai/codex login",
    "codex-proxy": "npx openai-oauth",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:mac:arm": "electron-builder --mac --arm64",
    "build:mac:intel": "electron-builder --mac --x64",
    "build:all": "electron-builder -mwl"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.16",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "https-proxy-agent": "^9.0.0",
    "openai": "^4.73.0",
    "openai-oauth": "^1.0.2",
    "pino": "^9.5.0",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "^4.8.1",
    "socks-proxy-agent": "^10.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.whatsapp.autofeeding",
    "productName": "WhatsApp Auto Feeding",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "client/dist/**/*",
      "server/**/*",
      "src/**/*",
      "index.js",
      "package.json",
      "node_modules/**/*",
      ".env.example"
    ],
    "asar": true,
    "asarUnpack": [
      "client/dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": null
  }
}
