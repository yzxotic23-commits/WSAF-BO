# ============================================
# AI PROVIDER CONFIG
# ============================================
AI_PROVIDER_PRIMARY=openai
AI_PROVIDER_FALLBACK=ollama

# --- OpenAI auth mode ---
# api_key  = billing API key (sk-...)
# codex    = subscription ChatGPT/Codex via OAuth (no API credits)
# auto     = try API key first, then Codex OAuth if no key
OPENAI_AUTH_MODE=codex

# API key (only for OPENAI_AUTH_MODE=api_key or auto fallback)
OPENAI_API_KEY=
OPENAI_MODEL=auto

# Codex OAuth (after: npm run codex-login)
# Token file: ~/.codex/auth.json (same as Codex CLI)
# CODEX_AUTH_FILE=C:\Users\You\.codex\auth.json
# CODEX_PROXY_HOST=127.0.0.1
# CODEX_PROXY_PORT=10531

# --- Ollama fallback (free, local) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_PARALLEL=1

# ============================================
# ACCOUNT CONFIG
# ============================================
PAIR_COUNT=1
ACCOUNT_START=1

# ============================================
# CHAT CONFIG
# ============================================
MIN_DELAY=30
MAX_DELAY=90
TOPICS=
MAX_MESSAGES=20
LANGUAGE=Indonesia

PAIR_IDLE_TIMEOUT=600
PAIR_STOP_ON_IDLE=false
PAIR_NUDGE_AFTER=90
PAIR_MAX_NUDGES=3
ECHO_IGNORE_MS=60000

# ============================================
# DESKTOP APP AUTO-UPDATE
# ============================================
# URL folder hosting latest.yml + WhatsApp.Setup.x.exe (must end with /)
# APP_UPDATE_URL=https://your-server.com/wa-updates/
# APP_UPDATE_CHECK_HOURS=4
